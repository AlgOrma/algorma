# SQLite database file (relative to the backend/ working directory)
DATABASE_URL=sqlite:///./algorma.db

# Extra allowed CORS origin, for a deployed (non-localhost) frontend.
# Local dev needs no config: any http://localhost:<port> origin is always
# accepted (see the CORS regex in app/main.py).
WEB_ORIGIN=http://localhost:5199

# Feature flags — flashcards UI isn't implemented yet, so its API is off by
# default. Mirrors FEATURES.flashcards in frontend/src/features.js.
ENABLE_FLASHCARDS=false
