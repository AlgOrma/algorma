# SQLite database file (relative to the backend/ working directory)
DATABASE_URL=sqlite:///./algorma.db

# Browser origins allowed to call this API with the session cookie, as a
# comma-separated list. This is an explicit allow-list — no other origin is
# trusted, including other ports on your own machine. (Arbitrary localhost
# ports used to be accepted; that let any other local process ride a logged-in
# session, so it's gone.) The default covers `npm run dev`; add entries for a
# custom Vite PORT, `vite preview` (4173), or a deployed frontend, e.g.
#   WEB_ORIGIN=https://algorma.example.com,http://localhost:4173
# Each localhost entry also implies its 127.0.0.1 form and vice versa. Leave
# empty if one process serves both the API and the built UI (no CORS needed).
WEB_ORIGIN=http://localhost:5199

# Feature flags — flashcards UI isn't implemented yet, so its API is off by
# default. Mirrors FEATURES.flashcards in frontend/src/features.js.
ENABLE_FLASHCARDS=false

# ---- Authentication (AUTH_DESIGN.md) ----
# Every value below has a working default for local dev.

# REQUIRED on any HTTPS deployment: marks the session cookie Secure.
COOKIE_SECURE=false

# REQUIRED behind a reverse proxy (Caddy/nginx/Traefik, or a PaaS router):
# run uvicorn with forwarded-header handling, e.g.
#   uvicorn app.main:app --proxy-headers --forwarded-allow-ips="<proxy-ip>"
# (use the proxy's actual IP; "*" only if nothing untrusted can reach the port).
# This is not cosmetic — without it every request looks like it came from the
# proxy, so:
#   1. Login/register rate limiting keys on the proxy's IP, putting the WHOLE
#      instance in one bucket: 10 failed logins from one attacker locks out
#      every user for the minute. Cheap, total DoS.
#   2. OAuth builds an http:// redirect_uri behind TLS termination, which
#      Google and GitHub reject as a redirect-URI mismatch.

# Sliding session lifetime (server-side) and the "remember me" cookie age.
SESSION_TTL_DAYS=30

# Set false to make the instance invite-only: /api/auth/register returns 403
# and OAuth sign-ins only work for already-existing accounts.
ALLOW_REGISTRATION=true

# Where OAuth round-trips (and their ?error= failures) land. Set this to the
# public frontend URL on a deployed instance.
FRONTEND_URL=http://localhost:5199

# Signs the short-lived OAuth handshake cookie (Authlib state/PKCE). Optional
# for email/password-only instances; REQUIRED when OAuth is enabled and
# uvicorn runs more than one worker (each worker would otherwise generate its
# own key). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#SESSION_SECRET=

# OAuth providers: a provider's "Continue with …" button appears automatically
# when both of its values are set. Register the redirect URI as
#   <api-origin>/api/auth/<provider>/callback
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
