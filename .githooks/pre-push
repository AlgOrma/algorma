#!/usr/bin/env sh
#
# Pre-push checks for AlgOrma: frontend lint + build, backend ruff.
# Enable once with:  git config core.hooksPath .githooks
# Skip in a pinch with:  git push --no-verify
#
set -e

ROOT="$(git rev-parse --show-toplevel)"
echo "▶ Running pre-push checks…"

# --- Frontend: lint + production build ---
if [ -d "$ROOT/frontend/node_modules" ]; then
  echo "→ frontend: oxlint"
  ( cd "$ROOT/frontend" && npm run --silent lint )
  echo "→ frontend: build"
  ( cd "$ROOT/frontend" && npm run --silent build )
else
  echo "⚠ frontend/node_modules missing — run 'npm install' in frontend/. Skipping frontend checks."
fi

# --- Backend: ruff lint ---
if [ -x "$ROOT/backend/.venv/bin/ruff" ]; then
  RUFF="$ROOT/backend/.venv/bin/ruff"
elif command -v ruff >/dev/null 2>&1; then
  RUFF="ruff"
else
  RUFF=""
  echo "⚠ ruff not found — run 'pip install -r backend/requirements-dev.txt'. Skipping backend checks."
fi
if [ -n "$RUFF" ]; then
  echo "→ backend: ruff"
  ( cd "$ROOT/backend" && "$RUFF" check . )
fi

echo "✓ All pre-push checks passed."
